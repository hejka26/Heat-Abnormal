import {
    RustActions,
    GrayHistogramState,
    RGBHistogramState,
    ProfileLineState,
} from "../global/event_bus.slint";
import { Button, StyleMetrics, Slider, LineEdit, ComboBox, Palette } from "std-widgets.slint";
import { SlidingPanel, PanelSide } from "./sliding_panel.slint";
import { RightPanelState } from "../widgets/right_panel_states.slint";
import { Histogram } from "../widgets/histogram.slint";
import { HistTable } from "../widgets/hist_table.slint";
import { ImageStore } from "../global/image_data.slint";

export component RightPanel inherits SlidingPanel {
    in-out property <RightPanelState> PanelState;
    property <string> title;

    property <float> canny-low-val: 50;
    property <float> canny-high-val: 150;
    property <int> linear-border-idx: 0;

    side: PanelSide.Right;
    width: 750px;

    VerticalLayout {
        padding: StyleMetrics.layout-padding;
        spacing: StyleMetrics.layout-spacing;

        HorizontalLayout {
            vertical-stretch: 0;
            alignment: space-between;

            Button {
                text: "↩";

                clicked => {
                    root.close-panel();
                }
            }

            Text {
                text: title;
            }

            Button {
                text: "🗙";

                clicked => {
                    PanelState = RightPanelState.None;
                    root.close-panel();
                }
            }
        }

        if PanelState == RightPanelState.Histogram || PanelState == RightPanelState.StretchHistogram: Histogram {
            init() => {
                title = "Histogram";
                RustActions.calculate-gray-histogram()
            }
            bar-spacing: 0px;
            data: GrayHistogramState.data;
            max-value: GrayHistogramState.max-value;
            mean: GrayHistogramState.mean;
            std-dev: GrayHistogramState.std-dev;
        }

        if PanelState == RightPanelState.StretchHistogram: VerticalLayout {
            spacing: 5px;

            init() => {
                title = "Stretch histogram";
                RustActions.calculate-gray-histogram()
            }
            // Suwak dla wartości P1
            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "p1: " + round(p1-slider.value);
                    width: 60px;
                    vertical-alignment: center;
                }

                p1-slider := Slider {
                    minimum: 0;
                    maximum: p2-slider.value - 1;
                    value: 0;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "p2: " + round(p2-slider.value);
                    width: 60px;
                    vertical-alignment: center;
                }

                p2-slider := Slider {
                    minimum: p1-slider.value + 1;
                    maximum: 255;
                    value: 255;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "q3: " + round(q3-slider.value);
                    width: 60px;
                    vertical-alignment: center;
                }

                q3-slider := Slider {
                    minimum: 0;
                    maximum: q4-slider.value - 1;
                    value: 0;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "q4: " + round(q4-slider.value);
                    width: 60px;
                    vertical-alignment: center;
                }

                q4-slider := Slider {
                    minimum: q3-slider.value + 1;
                    maximum: 255;
                    value: 255;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.selective-stretch(
                        round(p1-slider.value), 
                        round(p2-slider.value),
                        round(q3-slider.value),
                        round(q4-slider.value)
                    );
                }
            }
        }

        if PanelState == RightPanelState.HistogramTable: HistTable {
            init() => {
                title = "Table";
                RustActions.calculate-gray-histogram()
            }
            bar-spacing: 0px;
            data: GrayHistogramState.data;
            max-value: GrayHistogramState.max-value;
            mean: GrayHistogramState.mean;
            std-dev: GrayHistogramState.std-dev;
            total-pixels: GrayHistogramState.total-pixels;
        }

        if PanelState == RightPanelState.Posterize: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;

            init() => {
                title = "Posterization";
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Level: " + round(levels-slider.value);
                    width: 80px;
                    vertical-alignment: center;
                }

                levels-slider := Slider {
                    minimum: 2;   // Minimum 2 poziomy (czarny i biały)
                    maximum: 128; // Zbyt wysokie wartości i tak nie mają sensu wizualnego
                    value: 4;     // Domyślnie redukujemy do 4 poziomów
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.posterize(round(levels-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.ThresholdSegmentation: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;

            init() => {
                title = "Thresholding Segmentation";
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Threshold: " + round(threshold-slider.value);
                    width: 100px;
                    vertical-alignment: center;
                }

                threshold-slider := Slider {
                    minimum: 0;
                    maximum: 255;
                    value: 128;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.segment(round(threshold-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.MedianFilter: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;

            init() => {
                title = "Median Filter";
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Kernel Size: " + (round(kernel-slider.value) * 2 + 1);
                    width: 120px;
                    vertical-alignment: center;
                }

                kernel-slider := Slider {
                    minimum: 1;
                    maximum: 5;
                    value: 1;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.median-filter(round(kernel-slider.value) * 2 + 1);
                }
            }
        }

        if PanelState == RightPanelState.Dilation: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;

            init() => {
                title = "Dilation";
            }

            HorizontalLayout {
                spacing: 10px;
                Text {
                    text: "Iterations: " + round(iter-slider.value);
                    width: 100px;
                    vertical-alignment: center;
                }

                iter-slider := Slider {
                    minimum: 1;
                    maximum: 10;
                    value: 1;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.dilate(round(iter-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.CustomFilter: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;

            init() => {
                title = "Custom Mask (3x3)";
            }

            GridLayout {
                spacing: 5px;
                m00 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                m01 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                m02 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                Row {
                    m10 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                    m11 := LineEdit { text: "1"; placeholder-text: "1"; width: 60px; }
                    m12 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                }
                Row {
                    m20 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                    m21 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                    m22 := LineEdit { text: "0"; placeholder-text: "0"; width: 60px; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Border:"; vertical-alignment: center; }
                border-combo := ComboBox {
                    model: ["isolated", "replicate", "reflect"];
                    current-index: 0;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.custom-filter(
                        m00.text.to-float(), m01.text.to-float(), m02.text.to-float(),
                        m10.text.to-float(), m11.text.to-float(), m12.text.to-float(),
                        m20.text.to-float(), m21.text.to-float(), m22.text.to-float(),
                        border-combo.current-index
                    );
                }
            }
        }

        if PanelState == RightPanelState.LinearFilters: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Linear Filters"; }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Filter:"; vertical-alignment: center; }
                filter-combo := ComboBox {
                    model: ["Blur", "Sharpen", "Laplacian", "Sobel X", "Sobel Y", "Prewitt X", "Prewitt Y", "Canny"];
                    current-index: 0;
                }
            }

            if filter-combo.current-index == 7: VerticalLayout {
                spacing: 10px;
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "Low:"; vertical-alignment: center; }
                    Slider { 
                        minimum: 0; 
                        maximum: 255; 
                        value: root.canny-low-val;
                        changed(v) => { root.canny-low-val = v; }
                    }
                }
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "High:"; vertical-alignment: center; }
                    Slider { 
                        minimum: 0; 
                        maximum: 255; 
                        value: root.canny-high-val;
                        changed(v) => { root.canny-high-val = v; }
                    }
                }
            }

            if filter-combo.current-index != 7: HorizontalLayout {
                spacing: 10px;
                Text { text: "Border:"; vertical-alignment: center; }
                ComboBox {
                    model: ["isolated", "replicate", "reflect"];
                    current-index: root.linear-border-idx;
                    selected(s) => {
                        if s == "isolated" { root.linear-border-idx = 0; }
                        if s == "replicate" { root.linear-border-idx = 1; }
                        if s == "reflect" { root.linear-border-idx = 2; }
                    }
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    if filter-combo.current-index == 7 {
                        RustActions.canny-edge(root.canny-low-val, root.canny-high-val);
                    } else {
                        RustActions.linear-filter(filter-combo.current-index, root.linear-border-idx);
                    }
                }
            }
        }

        if PanelState == RightPanelState.TwoArgumentOp: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Two Argument Operation"; }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Op:"; vertical-alignment: center; }
                op-combo := ComboBox {
                    model: ["Add", "Sub", "Blend", "AND", "OR", "XOR"];
                    current-index: 0;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Second Image:"; vertical-alignment: center; }
                img-slider := Slider {
                    minimum: 0;
                    maximum: ImageStore.loaded-images.length - 1;
                    value: 0;
                }
                Text { text: round(img-slider.value) + " (" + ImageStore.loaded-images[round(img-slider.value)].label + ")"; vertical-alignment: center; }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.two-argument-op(op-combo.current-index, round(img-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.TwoStageFilter: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Two Stage Filter (5x5)"; }

            Text { text: "Mask 1 (3x3)"; }
            GridLayout {
                spacing: 2px;
                a00 := LineEdit { text: "0.111"; width: 45px; }
                a01 := LineEdit { text: "0.111"; width: 45px; }
                a02 := LineEdit { text: "0.111"; width: 45px; }
                Row {
                    a10 := LineEdit { text: "0.111"; width: 45px; }
                    a11 := LineEdit { text: "0.111"; width: 45px; }
                    a12 := LineEdit { text: "0.111"; width: 45px; }
                }
                Row {
                    a20 := LineEdit { text: "0.111"; width: 45px; }
                    a21 := LineEdit { text: "0.111"; width: 45px; }
                    a22 := LineEdit { text: "0.111"; width: 45px; }
                }
            }

            Text { text: "Mask 2 (3x3)"; }
            GridLayout {
                spacing: 2px;
                b00 := LineEdit { text: "0"; width: 45px; }
                b01 := LineEdit { text: "-1"; width: 45px; }
                b02 := LineEdit { text: "0"; width: 45px; }
                Row {
                    b10 := LineEdit { text: "-1"; width: 45px; }
                    b11 := LineEdit { text: "5"; width: 45px; }
                    b12 := LineEdit { text: "-1"; width: 45px; }
                }
                Row {
                    b20 := LineEdit { text: "0"; width: 45px; }
                    b21 := LineEdit { text: "-1"; width: 45px; }
                    b22 := LineEdit { text: "0"; width: 45px; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Border:"; vertical-alignment: center; }
                ts-border-combo := ComboBox {
                    model: ["isolated", "replicate", "reflect"];
                    current-index: 0;
                }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.two-stage-filter(
                        a00.text.to-float(), a01.text.to-float(), a02.text.to-float(),
                        a10.text.to-float(), a11.text.to-float(), a12.text.to-float(),
                        a20.text.to-float(), a21.text.to-float(), a22.text.to-float(),
                        b00.text.to-float(), b01.text.to-float(), b02.text.to-float(),
                        b10.text.to-float(), b11.text.to-float(), b12.text.to-float(),
                        b20.text.to-float(), b21.text.to-float(), b22.text.to-float(),
                        ts-border-combo.current-index
                    );
                }
            }
        }

        if PanelState == RightPanelState.Morphology: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Morphology"; }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Op:"; vertical-alignment: center; }
                morph-op-combo := ComboBox {
                    model: ["Erode", "Dilate", "Open", "Close"];
                    current-index: 0;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Element:"; vertical-alignment: center; }
                morph-elem-combo := ComboBox {
                    model: ["Rectangle", "Cross", "Ellipse"];
                    current-index: 0;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Iterations: " + round(morph-iter-slider.value); vertical-alignment: center; }
                morph-iter-slider := Slider { minimum: 1; maximum: 10; value: 1; }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.morphology(morph-op-combo.current-index, morph-elem-combo.current-index, round(morph-iter-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.HoughTransform: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Hough Transform"; }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Rho: " + round(rho-slider.value * 10)/10; width: 80px; }
                rho-slider := Slider { minimum: 0.1; maximum: 5.0; value: 1.0; }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Theta: " + round(theta-slider.value); width: 80px; }
                theta-slider := Slider { minimum: 1; maximum: 180; value: 1; }
            }

            HorizontalLayout {
                spacing: 10px;
                Text { text: "Threshold: " + round(hough-thresh-slider.value); width: 100px; }
                hough-thresh-slider := Slider { minimum: 10; maximum: 500; value: 100; }
            }

            Button {
                text: "Apply";
                clicked => {
                    RustActions.hough-lines(rho-slider.value, theta-slider.value, round(hough-thresh-slider.value));
                }
            }
        }

        if PanelState == RightPanelState.ProfileLine: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Profile Line"; }

            GridLayout {
                spacing: 10px;
                Text { text: "X1:"; } x1-edit := LineEdit { text: "0"; width: 60px; }
                Text { text: "Y1:"; } y1-edit := LineEdit { text: "0"; width: 60px; }
                Row {
                    Text { text: "X2:"; } x2-edit := LineEdit { text: "100"; width: 60px; }
                    Text { text: "Y2:"; } y2-edit := LineEdit { text: "100"; width: 60px; }
                }
            }

            Button {
                text: "Calculate Profile";
                clicked => {
                    RustActions.profile-line(x1-edit.text.to-float(), y1-edit.text.to-float(), x2-edit.text.to-float(), y2-edit.text.to-float());
                }
            }

            Rectangle {
                height: 200px;
                background: Palette.alternate-background;
                border-radius: 4px;
                
                HorizontalLayout {
                    padding: 4px;
                    spacing: 1px;
                    for val in ProfileLineState.data: Rectangle {
                        y: parent.height - self.height;
                        height: parent.height * (val / ProfileLineState.max-value);
                        background: Palette.accent-background;
                    }
                }
            }
        }

        if PanelState == RightPanelState.ImagePyramid: VerticalLayout {
            spacing: 15px;
            alignment: center;
            vertical-stretch: 1;
            init() => { title = "Image Pyramid"; }

            HorizontalLayout {
                spacing: 10px;
                Button {
                    text: "Pyr Down (1/2)";
                    clicked => { RustActions.image-pyramid(0); }
                }
                Button {
                    text: "Pyr Up (2x)";
                    clicked => { RustActions.image-pyramid(1); }
                }
            }
        }
    }
}
