import {
    VerticalBox,
    HorizontalBox,
    Button,
    Palette,
    StyleMetrics,
} from "std-widgets.slint";

export enum PanelSide { Left, Right }

export component SlidingPanel inherits Rectangle {
    in property <bool> is-open: false;
    in property <PanelSide> side: PanelSide.Left;
    in property <length> parent-width; // We still need this to know where the right edge is

    callback close-panel();

    // 1. Animate a 'progress' float instead of the physical X coordinate
    property <float> progress: root.is-open ? 1.0 : 0.0;
    animate progress {
        duration: 300ms;
        easing: ease-in-out;
    }

    // 2. X calculates itself dynamically based on whatever `self.width` currently is
    x: root.side == PanelSide.Left ? -self.width + (self.width * progress) : parent-width - (self.width * progress);

    background: Palette.alternate-background;
    border-width: 1px;
    border-color: Palette.border;
    clip: true;

    drop-shadow-color: root.is-open ? #00000020 : transparent;
    drop-shadow-blur: 15px;

    @children
}
